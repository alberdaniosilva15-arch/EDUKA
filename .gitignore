# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# mimocode (evita duplicação de lockfile no Next.js)
.mimocode/
# backup de debug
.backup-debug/

# ficheiros locais e de seguranca
codigo-seguranca.txt
conversa.txt
build_error.txt
eduka-full-report.txt
dev-server*.log

build*.log
check-db.js
test-*.js
*.pptx
